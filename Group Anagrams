from collections import defaultdict

class Solution:
    def groupAnagrams(self, strs):
        d = defaultdict(list)
        
        for word in strs:
            s_word = "".join(sorted(word))   # fixed
            d[s_word].append(word)
        
        result = []
        for key in d:
            result.append(d[key])
        
        return result
